module priority_enc_tb ;

// local inputs and outputs declaration 
logic clk, rst, valid ;
logic [3:0]D ;
logic [1:0]Y ;

// integers to count errors and correct tests 
integer error_count ;
integer correct_count ; 

// creating an instant and instantiate it 

priority_enc DUT(
.clk(clk),
.rst(rst),
.valid(valid),
.D(D),
.Y(Y)
);

// creating a clock to synchronise the testbench 
initial clk = 0;
always #5 clk = ~clk;


// starting the initial block 
initial begin 

// intializing all inputs and created integers to zero 
  D = 0 ;
  error_count = 0 ;
  correct_count = 0 ;

// calling reset task to check the reset
  assert_reset();

// Applying testing scenarios each with self checking the output 
  // ENCODER_1
  D = 4'b0000 ;
  check_result(2'bxx , 0) ;

  // ENCODER_2
  D = 4'b1000 ;
  check_result(0 , 1) ;

  // ENCODER_3
  D = 4'b0100 ;
  check_result(1 , 1) ;

  // ENCODER_4
  D = 4'b0010 ;
  check_result(2 , 1) ;

  // ENCODER_5
  D = 4'b0001 ;
  check_result(3 , 1) ;

  // ENCODER_6
  D = 4'b1000 ;
  check_result(0 , 1) ;

  // ENCODER_7
  D = 4'bx100 ;
  check_result(1 , 1) ;

  // ENCODER_8
  D = 4'bxx10 ;
  check_result(2 , 1) ;

  // ENCODER_9
  D = 4'bxxx1 ;
  check_result(3 , 1) ;

 rst = 1 ;

// display the the calculated integers and stop simulation 

  $display("================================================");
  $display("Summary: correct_count = %0d, error_count = %0d", correct_count, error_count);
  $display("================================================");
  

end  

// writing the body of used tasks 

task assert_reset() ; 
// assert reset 
rst = 1 ; 
// check low output 
check_result(0,0) ; 
// deassert reset 
rst = 0 ;
endtask 

task check_result(input logic [1:0]expected_Y , input logic expected_valid) ;
@(negedge clk) ;
if(expected_Y == Y && expected_valid == valid) begin 
correct_count = correct_count + 1 ;
end 
else begin 
error_count = error_count + 1 ;
$display("%t: Error : for D = %0d , Y should equal %0d but its equal %0d",$time, D, expected_Y, Y);

end 
endtask 

// ending the module
endmodule  
